# ========== 1. Python核心文件 (必须) ==========
# 忽略Python字节码和缓存文件
__pycache__/
*.py[cod]
*.so

# ========== 2. 虚拟环境 (必须) ==========
# 忽略项目根目录下的常见虚拟环境目录
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/

# ========== 3. PyCharm/IDEA项目文件 ==========
# 整个.idea目录都应被忽略，它包含你的个人项目配置
.idea/
# 忽略项目根目录下的.iml模块文件
*.iml

# ========== 4. 测试与覆盖率报告 ==========
# 这些文件通常由pytest等工具自动生成
.pytest_cache/
.coverage
htmlcov/

# ========== 5. 其他常见类型 ==========
# 环境变量文件 (包含敏感信息，务必忽略)
.env
.env.local
# 日志文件
*.log
# 操作系统生成的文件
.DS_Store  # macOS
Thumbs.db   # Windows